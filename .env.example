# Server Configuration
PORT=3000

# SMTP Configuration (e.g. Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# The email address used to log into the SMTP server to actually send the mail
SMTP_USER=your_email@gmail.com
# For Gmail, you must generate an "App Password" rather than using your login password
SMTP_PASS=your_app_password_here

# Administrator Configuration
# The email address where you want to RECEIVE the incoming leads/inquiries
ADMIN_EMAIL=your_email@gmail.com
# Shared secret required in the x-admin-key header to access /api/admin/* routes.
# Use a long, random value (32+ chars) — this is the only thing gating the admin API.
ADMIN_SECRET_KEY=change_this_to_a_long_random_value

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=Cluster0

# Cloudinary (PDF upload storage) — required for /api/admin/solutions PDF uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Gemini (AI solution generation) — required for /api/admin/generate-solution
GEMINI_API_KEY=your_gemini_api_key